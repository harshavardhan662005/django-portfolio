{
  "version": 2,
  "framework": "django",
  "builds": [
    {
      "src": "config/wsgi.py",
      "use": "@vercel/python",
      "config": { 
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "build": {
    "env": {
      "ENABLE_UV": "0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "config/wsgi.py"
    }
  ]
}